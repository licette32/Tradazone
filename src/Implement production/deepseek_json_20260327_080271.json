// package.json - Add bundle size check script
{
  "scripts": {
    "build:analyze": "npm run build && npx bundle-stats",
    "size:check": "bundlesize",
    "prebuild": "npm run size:check"
  },
  "bundlesize": [
    {
      "path": "build/static/js/*.js",
      "maxSize": "100 kB",
      "compression": "gzip"
    },
    {
      "path": "build/static/css/*.css",
      "maxSize": "50 kB"
    },
    {
      "path": "build/static/js/invoice-detail*.js",
      "maxSize": "50 kB",
      "compression": "gzip"
    }
  ]
}